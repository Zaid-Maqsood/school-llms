# Database
# Local development:
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/your_db_name
# DigitalOcean (use their injected variable):
# DATABASE_URL=${production-database.DATABASE_URL}
DB_SCHEMA=school_ms

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# CORS - frontend URL
CORS_ORIGIN=http://localhost:5173

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Future: Cloud Storage (leave blank for local dev)
# STORAGE_PROVIDER=local
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
