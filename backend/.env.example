# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grayphite
DB_SCHEMA=school_ms
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# CORS - frontend URL
CORS_ORIGIN=http://localhost:5173

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Future: Cloud Storage (leave blank for local dev)
# STORAGE_PROVIDER=local
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
